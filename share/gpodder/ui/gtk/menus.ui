<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <menu id="app-menu">
        <!-- RobL - ======================================= -->
        <!-- RobL - Menubar -> gPodder+ (application level) -->
        <!-- RobL - (changed menubar option from gPodder)   -->
        <!-- RobL - ======================================= -->
        <section>
            <item>
                <attribute name="action">app.preferences</attribute>
                <attribute name="label" translatable="yes">Preferences</attribute>
                <attribute name="accel">&lt;Primary&gt;p</attribute>
            </item>
        </section>
        <section>
            <item>
                <attribute name="action">app.gotoMygpo</attribute>
                <attribute name="label" translatable="yes">Go to gpodder.net</attribute>
            </item>
            <item>
                <attribute name="action">app.checkForUpdates</attribute>
                <attribute name="label" translatable="yes">Software updates</attribute>
            </item>
        </section>
        <section>
            <item>
                <attribute name="label" translatable="yes">Open Logs</attribute>
                <attribute name="action">app.logs</attribute>
            </item>
            <!-- RobL - Changed to be explicitly online help -->
            <item>
                <attribute name="label" translatable="yes">Help (online)</attribute>
                <attribute name="action">app.helpOnline</attribute>
            </item>
            <!-- RobL - Added local help file option -->
            <item>
                <attribute name="label" translatable="yes">Help (local)</attribute>
                <attribute name="action">app.helpLocal</attribute>
            </item>
            <item>
                <attribute name="action">app.about</attribute>
                <attribute name="label" translatable="yes">About</attribute>
            </item>
            <item>
                <attribute name="action">app.quit</attribute>
                <attribute name="label" translatable="yes">Quit</attribute>
                <attribute name="accel">&lt;Primary&gt;q</attribute>
            </item>
        </section>
    </menu>
    <menu id="menubar">
        <!-- RobL - ========================================================================= -->
        <!-- RobL - Menubar -> Podcast (manages the selected podcast)                         -->
        <!-- RobL - (multiple actions were changed from all podcasts to the selected podcast) -->
        <!-- RobL - ========================================================================= -->
        <submenu id="menuPodcast">
            <attribute name="label" translatable="yes">_Podcast</attribute>
            <section>
                <item>
                    <attribute name="action">win.showPodcastDetails</attribute>
                    <attribute name="label" translatable="yes">Podcast Details...</attribute>
                </item>
                <item>
                    <attribute name="action">win.updateSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Update Selected Podcast</attribute>
                </item>
                <item>
                    <attribute name="action">win.findEpisodeSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Find Episode</attribute>
                    <attribute name="accel">&lt;Primary&gt;f</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.manualEditPodcast</attribute>
                    <attribute name="label" translatable="yes">Edit Podcast Settings...</attribute>
                </item>
                <item>
                    <attribute name="action">win.manualAddPodcast</attribute>
                    <attribute name="label" translatable="yes">Add New Podcast (manually)...</attribute>
                </item>
                <item>
                    <attribute name="action">win.manualAddEpisodeSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Add New Episode (manually)...</attribute>
                </item>
                <item>
                    <attribute name="action">win.manualAddEpisodeBatchSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Add Multiple Episodes (manually)...</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.allEpisodesNewSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">All Episodes - New</attribute>
                </item>
                <item>
                    <attribute name="action">win.allEpisodesLockSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">All Episodes - Lock</attribute>
                </item>
                <item>
                    <attribute name="action">win.autoLockNewEpisodesSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Auto-Lock New Episodes</attribute>
                </item>
                <item>
                    <attribute name="action">win.undeleteEpisodesSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Restore Deleted Episodes</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.removeSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Remove Podcast</attribute>
                </item>
                <item>
                    <attribute name="action">win.removeDeletedEpisodesSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Remove Deleted Episodes</attribute>
                </item>
                <item>
                    <attribute name="action">win.deleteExpiredEpisodesSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Delete Expired Episodes</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.openPodcastDownloadFolder</attribute>
                    <attribute name="label" translatable="yes">Open Download Folder</attribute>
                </item>
                <item>
                    <attribute name="action">win.refreshPodcastImage</attribute>
                    <attribute name="label" translatable="yes">Refresh Podcast Image</attribute>
                </item>
            </section>
        </submenu>
        <!-- RobL - ===================================================== -->
        <!-- RobL - Menubar -> Episode (manages selected podcast episode) -->
        <!-- RobL - (multiple actions were changed for selected episodes) -->
        <!-- RobL - ===================================================== -->
        <submenu id="menuEpisode">
            <attribute name="label" translatable="yes">_Episode</attribute>
            <section>
                <item>
                    <attribute name="action">win.play</attribute>
                    <attribute name="label" translatable="yes">Play</attribute>
                    <attribute name="accel">&lt;Shift&gt;Return</attribute>
                </item>
                <item>
                    <attribute name="action">win.open</attribute>
                    <attribute name="label" translatable="yes">Open</attribute>
                </item>
                <item>
                    <attribute name="action">win.download</attribute>
                    <attribute name="label" translatable="yes">Download</attribute>
                </item>
                <item>
                    <attribute name="action">win.pause</attribute>
                    <attribute name="label" translatable="yes">Pause</attribute>
                </item>
                <item>
                    <attribute name="action">win.cancel</attribute>
                    <attribute name="label" translatable="yes">Cancel</attribute>
                </item>
                <item>
                    <attribute name="action">win.delete</attribute>
                    <attribute name="label" translatable="yes">Delete</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.manualEditEpisodeSelectedPodcast</attribute>
                    <attribute name="label" translatable="yes">Edit Episode...</attribute>
                </item>
                <item>
                    <attribute name="action">win.episodeNew</attribute>
                    <attribute name="label" translatable="yes">New</attribute>
                </item>
                <item>
                    <attribute name="action">win.episodeLock</attribute>
                    <attribute name="label" translatable="yes">Lock</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.openEpisodeDownloadFolder</attribute>
                    <attribute name="label" translatable="yes">Open Download Folder</attribute>
                </item>
                <item>
                    <attribute name="action">win.selectChannel</attribute>
                    <attribute name="label" translatable="yes">Highlight Associated Podcast</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.findEpisode</attribute>
                    <attribute name="label" translatable="yes">Find Episode</attribute>
                    <attribute name="accel">&lt;Primary&gt;f</attribute>
                </item>
                <item>
                    <attribute name="action">win.toggleShownotes</attribute>
                    <attribute name="label" translatable="yes">Toggle Episode Details (show/hide)</attribute>
                </item>
            </section>
        </submenu>
        <!-- RobL - =================================================== -->
        <!-- RobL - Menubar -> All Podcasts - (applies to all podcasts) -->
        <!-- RobL - (menubar option added that applies to all podcasts) -->
        <!-- RobL - =================================================== -->
        <submenu id="menuAllPodcasts">
            <attribute name="label" translatable="yes">_All Podcasts</attribute>
            <section>
                <item>
                    <attribute name="action">win.checkForNewEpisodesAllPodcasts</attribute>
                    <attribute name="label" translatable="yes">Check for New Episodes</attribute>
                    <attribute name="accel">&lt;Primary&gt;r</attribute>
                </item>
                <item>
                    <attribute name="action">win.downloadNewEpisodesAllPodcasts</attribute>
                    <attribute name="label" translatable="yes">Download New Episodes</attribute>
                    <attribute name="accel">&lt;Primary&gt;n</attribute>
                </item>
                <item>
                    <attribute name="action">win.updateAllPodcasts</attribute>
                    <attribute name="label" translatable="yes">Update Podcasts</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.deleteExpiredEpisodesAllPodcasts</attribute>
                    <attribute name="label" translatable="yes">Delete Expired Episodes</attribute>
                </item>
                <item>
                    <attribute name="action">win.deleteOldEpisodesAllPodcasts</attribute>
                    <attribute name="label" translatable="yes">Delete Old Episodes...</attribute>
                    <attribute name="accel">&lt;Primary&gt;k</attribute>
                </item>
                <item>
                    <attribute name="action">win.deleteMultiplePodcasts</attribute>
                    <attribute name="label" translatable="yes">Delete Podcasts...</attribute>
                </item>
            </section>
            <section>
                <item>
                    <attribute name="action">win.findPodcast</attribute>
                    <attribute name="label" translatable="yes">Find Podcast</attribute>
                    <attribute name="accel">&lt;Primary&gt;&lt;Shift&gt;f</attribute>
                </item>
            </section>
        </submenu>
        <!-- RobL - ==================================================================== -->
        <!-- RobL - Menubar -> Subscriptions (adds new podcasts based on a subscription) -->
        <!-- RobL - (menubar option moved and new actions that apply to new podcasts)    -->
        <!-- RobL - ==================================================================== -->
        <submenu id="menuSubscriptions">
            <attribute name="label" translatable="yes">_Subscriptions</attribute>
            <section>
                <item>
                    <attribute name="action">win.discover</attribute>
                    <attribute name="label" translatable="yes">Discover New Podcasts...</attribute>
                </item>
                <item>
                    <attribute name="action">win.addChannel</attribute>
                    <attribute name="label" translatable="yes">Add Podcast via URL...</attribute>
